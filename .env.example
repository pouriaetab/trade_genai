# Copy this file to `.env.local` and fill in your keys.
# `.env.local` is git-ignored — real keys never get committed.

# --- Market data (required) ---
MASSIVE_API_KEY=""
MASSIVE_REST_URL="https://api.massive.com"
MASSIVE_TIMEOUT_SECONDS="45"

# --- LLM providers (all optional) ---
# Add a key to light up that provider in the model picker. Leave blank to
# disable. A Claude.ai Pro/Max subscription is NOT an API key — get an API key
# from the Claude Developer Platform for ANTHROPIC_API_KEY.
#
# Free API tiers (good to start with, no cost):
GEMINI_API_KEY=""        # Google AI Studio — https://ai.google.dev  (free tier)
GROQ_API_KEY=""          # Groq, fast open models — https://console.groq.com  (free tier)
OPENROUTER_API_KEY=""    # Many models, one key — https://openrouter.ai  (free tier)
#
# Paid API tiers (billed per token, need a funded account):
ANTHROPIC_API_KEY=""     # https://platform.claude.com
OPENAI_API_KEY=""        # https://platform.openai.com
XAI_API_KEY=""           # https://docs.x.ai
